# Generated by jailoc — do not edit manually
name: jailoc-{{.WorkspaceName}}

services:
  opencode:
    image: {{.Image}}
    ports:
      - "{{.Port}}:4096"
    volumes:
{{- range .Paths}}
      - {{.}}:{{.}}
{{- end}}
{{- if .UseDataVolume}}
      - opencode-data-{{.WorkspaceName}}:/home/agent/.local/share/opencode
{{- end}}
{{- if .UseCacheVolume}}
      - opencode-cache-{{.WorkspaceName}}:/home/agent/.cache
{{- end}}
{{- range .Mounts}}
      - {{.}}
{{- end}}
      - ${HOME}/.config/jailoc/workspaces/{{.WorkspaceName}}:/etc/jailoc:ro
      - ${HOME}/.cache/jailoc/{{.WorkspaceName}}/entrypoint.sh:/usr/local/bin/entrypoint.sh:ro
      - dind-certs-client:/certs/client:ro
{{- if .SSHAuthSock}}
      - {{.SSHAuthSock}}:/run/ssh-agent.sock
{{- end}}
{{- if .GitConfig}}
      - {{.GitConfig}}:/home/agent/.gitconfig:ro
{{- end}}
{{- if .SSHKnownHosts}}
      - {{.SSHKnownHosts}}:/home/agent/.ssh/known_hosts:ro
{{- end}}
    environment:
      - OPENCODE_LOG=debug
      - JAILOC=1
      - JAILOC_WORKSPACE={{.WorkspaceName}}
      - OPENCODE_SERVER_PASSWORD={{.OpenCodePassword}}
      - DOCKER_HOST=tcp://dind:2376
      - DOCKER_TLS_CERTDIR=/certs
      - DOCKER_CERT_PATH=/certs/client
      - DOCKER_TLS_VERIFY=1
{{- if .SSHAuthSock}}
      - SSH_AUTH_SOCK=/run/ssh-agent.sock
{{- end}}
{{- range .Env}}
      - "{{.}}"
{{- end}}
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE  # bind to port 4096
      - NET_ADMIN         # iptables network restrictions
      - SETUID            # setpriv privilege drop
      - SETGID            # setpriv privilege drop
      - CHOWN             # chown data dirs before drop
      - FOWNER            # bypass ownership checks on chown
      - DAC_READ_SEARCH   # traverse restricted dirs during chown
    stdin_open: true
    tty: true
    mem_limit: "{{.Memory}}"
    memswap_limit: "{{.Memory}}"
    mem_reservation: 512m
    cpus: {{printf "%g" .CPU}}
    pids_limit: 256
    networks:
      - jailoc
    entrypoint: ["/usr/local/bin/entrypoint.sh"]
    command: ["opencode", "serve", "--hostname", "0.0.0.0", "--port", "4096", "--print-logs", "--log-level", "DEBUG"]
{{- if .Paths}}
    working_dir: {{index .Paths 0}}
{{- end}}
    healthcheck:
      test: ["CMD-SHELL", "curl -sf -u \"opencode:$$OPENCODE_SERVER_PASSWORD\" http://localhost:4096/global/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s

  dind:
    image: docker:dind
    privileged: true
    entrypoint:
      - sh
      - -c
      - |
        # Clean stale containerd state from prior unclean shutdown to prevent
        # "containerd is still running" crash loop (PID file persists on volume).
        # See: https://github.com/moby/moby/blob/v28.1.1/cmd/dockerd/daemon.go#L146-L160
        rm -f /var/lib/docker/containerd/containerd.pid \
              /var/lib/docker/containerd/containerd.sock \
              /var/lib/docker/containerd/containerd-debug.sock
        exec dockerd-entrypoint.sh "$$@"
      - --
    environment:
      - DOCKER_TLS_CERTDIR=/certs
      - DOCKER_TLS_SAN=DNS:dind
    volumes:
      - dind-certs-ca:/certs/ca
      - dind-certs-client:/certs/client
      - dind-data:/var/lib/docker
    dns:
      - 1.1.1.1
      - 8.8.8.8
    networks:
      - jailoc
    expose:
      - "2376"

volumes:
{{- if .UseDataVolume}}
  opencode-data-{{.WorkspaceName}}:
{{- end}}
{{- if .UseCacheVolume}}
  opencode-cache-{{.WorkspaceName}}:
{{- end}}
  dind-certs-ca:
  dind-certs-client:
  dind-data:

networks:
  jailoc:
